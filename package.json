    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-attributes": "^1.0.0",
